{
  "rules": [
    {
      "id": "hackathon-browser-uploads",
      "allowed": {
        "origins": [
          "http://localhost:5173",
          "http://localhost:8788",
          "https://hackathon.infrared.city",
          "https://hackathon-73i.pages.dev",
          "https://*.hackathon-73i.pages.dev"
