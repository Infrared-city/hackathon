{
  "name": "hackathon",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist --project-name hackathon",
    "pages:dev": "npm run build && wrangler pages dev dist --compatibility-date=2024-09-23 --port 8788",
    "test": "npx playwright test smoke-frontend",
    "test:unit": "npx playwright test validation",
    "test:integration": "npx playwright test smoke-integration",
    "test:upload": "BASE_URL=http://localhost:8788 npx playwright test smoke-upload",
    "test:all": "npx playwright test"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.10",
    "aws4fetch": "^1.0.20",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260529.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
